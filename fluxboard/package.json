{
  "name": "fluxboard",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:test": "vite build --base=/",
    "build:check": "tsc && vite build",
    "preview": "vite preview",
    "start": "vite preview --host 0.0.0.0",
    "check:node": "node ./scripts/check-node-version.cjs",
    "test": "vitest",
    "pretest": "pnpm run check:node",
    "lint": "tsc -p tsconfig.json",
    "test:run": "vitest run",
    "pretest:run": "pnpm run check:node",
    "test:full": "VITEST_FULL=1 vitest run",
    "pretest:full": "pnpm run check:node",
    "test:e2e": "node ./scripts/run-e2e.js",
    "test:e2e:prod": "pnpm run build:test && playwright test -c playwright.prod.config.ts",
    "test:e2e:smoke": "playwright test -c playwright.smoke.config.ts e2e/prod-smoke.spec.ts e2e/pnl.e2e.spec.ts"
  },
  "dependencies": {
    "@fontsource-variable/inter-tight": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.20.0",
    "@tanstack/react-virtual": "^3.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "decimal.js": "^10.4.3",
    "framer-motion": "^12.23.24",
    "katex": "^0.16.33",
    "lightweight-charts": "^5.1.0",
    "lodash-es": "^4.17.21",
    "lucide-react": "^0.552.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^1.5.2",
    "react-resizable": "^3.0.5",
    "react-router-dom": "^6.26.2",
    "socket.io-client": "^4.8.1",
    "sonner": "^1.5.0",
    "tailwind-merge": "^3.3.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.8.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/react-grid-layout": "^1.3.5",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^27.0.1",
    "postcss": "^8.4.47",
    "serve": "^14.2.1",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "vitest": "^3.2.4"
  }
}
