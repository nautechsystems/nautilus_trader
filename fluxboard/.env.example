# FluxAPI dev proxy target used by Vite (`/api/*`, `/socket.io`)
FLUXAPI_SCHEME=http
FLUXAPI_HOST=127.0.0.1
FLUXAPI_PORT=5022
# Optional explicit override (takes precedence over scheme/host/port)
# FLUXAPI_URL=http://127.0.0.1:5022

# Force same-origin Socket.IO in dev so Vite proxy handles `/socket.io`
VITE_BACKEND_URL=/
# Keep `VITE_BACKEND_URL=/` in proxy mode so Socket.IO stays same-origin and goes through the Vite proxy.
# If you set this to a concrete URL, ensure both REST and Socket.IO origins are intentionally aligned.

# Optional API base override for REST requests.
# Leave empty to use same-origin (`/api/*`) in both dev and prod-like modes.
# VITE_FLUXAPI_BASE_URL=

# Build base path for prod-like serving from FluxAPI.
# Keep `/tokenmm/` for TokenMM deep-link support.
FLUXBOARD_BASE_PATH=/tokenmm/

# Vite host/port defaults (localhost-only by default).
# VITE_DEV_HOST=127.0.0.1
# VITE_DEV_PORT=5173
# VITE_PREVIEW_HOST=127.0.0.1
# VITE_PREVIEW_PORT=4173
# VITE_ALLOWED_HOSTS=
# Keep VITE_ALLOWED_HOSTS explicit in any non-local environment; blank for localhost-only dev defaults.

# FX service base URL (optional - defaults to `/api`)
# VITE_FX_BASE_URL=/api

# -----------------------------------------------------------------------------
# Backend runner env vars (not consumed by Vite; set in shell before run_api.py)
# -----------------------------------------------------------------------------
# Enable prod-like static serving from FluxAPI runner
# FLUXBOARD_SERVE_DIST=1
# Optional override for built artifact directory
# FLUXBOARD_DIST=/path/to/fluxboard/dist
