# Quarterly USDM future. Update SYMBOLS each quarter when next contract lists.
# Format: <base><quote>_<YYMMDD>, e.g. BTCUSDT_250926 for Sep 2025 expiry.
#
# When a new quarterly contract is listed (~6 weeks pre-expiry), add it here
# alongside the current contract. Run both in parallel until the old one expires.

VENUE=umfutures
SYMBOLS=BTCUSDT_250627,BTCUSDT_250926
BUCKET=trading-data-CHANGEME
KEY_PREFIX=raw
PROM_PORT=9103
AWS_REGION=ap-northeast-1
