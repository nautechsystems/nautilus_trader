# Per-instance env file. Copy to /etc/binance-collector/binance-um-btc.env on the
# observability VM, then: systemctl enable --now binance-collector@binance-um-btc
#
# One env file per (venue, symbol-set) you want to collect. Each becomes a
# separate systemd unit instance, so they restart independently and have
# independent metrics labels.

VENUE=umfutures
SYMBOLS=BTCUSDT
BUCKET=trading-data-CHANGEME
KEY_PREFIX=raw
PROM_PORT=9101
AWS_REGION=ap-northeast-1
