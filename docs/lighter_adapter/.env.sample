# Lighter mainnet validation (fill in before running validation spike)
LIGHTER_ENV=mainnet

# Auth/signing (choose based on venue requirements)
# If signing requires a wallet private key (most likely for sendTx):
LIGHTER_WALLET_PRIVATE_KEY=REPLACE_ME
# If the venue issues API key material instead, fill these and leave private key blank:
LIGHTER_API_KEY=REPLACE_ME
LIGHTER_API_SECRET=REPLACE_ME

# Optional token if required for private REST/WS/sendTx (set if the venue issues one)
LIGHTER_AUTH_TOKEN=REPLACE_ME

# Account routing
LIGHTER_ACCOUNT_INDEX=REPLACE_ME
LIGHTER_API_KEY_INDEX=REPLACE_ME

# Rate limits and account tier
LIGHTER_ACCOUNT_TIER=standard  # or premium

# Network endpoints (override only if custom)
LIGHTER_HTTP_BASE=https://mainnet.zklighter.elliot.ai
LIGHTER_WS_BASE=wss://mainnet.zklighter.elliot.ai/stream

# Test order parameters (used for small-place-and-cancel validation)
LIGHTER_TEST_SYMBOL=BTCUSD-PERP
LIGHTER_TEST_SIZE=0.001
LIGHTER_TEST_PRICE=85000.0  # set to 0.0 for market-equivalent, or set a limit price
