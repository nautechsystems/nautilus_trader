# Copy to examples/live/makerv3/config/makerv3.live.env and fill in secrets.
BYBIT_API_KEY=
BYBIT_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Stack controls.
MAKERV3_MODE=live
MAKERV3_CONFIRM_LIVE=1
MAKERV3_ENABLE_EXECUTION=0
MAKERV3_ALLOW_MISSING_KEYS=0
MAKERV3_MANAGE_REDIS=1
MAKERV3_API_HOST=127.0.0.1
MAKERV3_API_PORT=5022
MAKERV3_START_TIMEOUT_SECS=60
MAKERV3_SKIP_FLUXBOARD_BUILD=0
MAKERV3_LOAD_AWS_SECRETS=1
MAKERV3_AWS_REGION=ap-southeast-1
MAKERV3_BYBIT_SECRET_ID=/nautilus/makerv3/bybit
MAKERV3_BINANCE_SECRET_ID=/nautilus/makerv3/binance

# Optional explicit paths.
# MAKERV3_CONFIG_PATH=/abs/path/to/examples/live/makerv3/config/makerv3.live.toml
# MAKERV3_ENV_PATH=/abs/path/to/examples/live/makerv3/config/makerv3.live.env
