# Optional TokenMM telemetry RDS metadata.
# The shipper reads `TOKENMM_AWS_REGION` and `NAUTILUS_TELEMETRY_PG_SECRET_ID`
# from `/etc/flux/common.env`; keep this file as the operator reference fragment.

TOKENMM_AWS_REGION=ap-southeast-1
NAUTILUS_TELEMETRY_PG_SECRET_ID=/nautilus/tokenmm/telemetry/postgres
NAUTILUS_TELEMETRY_PG_HOST=nautilus-tokenmm-telemetry.<rds-endpoint>.ap-southeast-1.rds.amazonaws.com
NAUTILUS_TELEMETRY_PG_PORT=5432
NAUTILUS_TELEMETRY_PG_DATABASE=nautilus_telemetry
NAUTILUS_TELEMETRY_PG_SCHEMA=telemetry
NAUTILUS_TELEMETRY_PG_SSLMODE=require
