# Copy to /etc/flux/tokenmm-jupyter.env for optional localhost-only research access.

PULSE_ENABLED=0
PULSE_DESCRIPTION=TokenMM JupyterLab
PULSE_GROUP_KEY=tokenmm
PULSE_GROUP_LABEL=TokenMM
PULSE_GROUP_ORDER=20
PULSE_SELF_SERVICE_ID=tokenmm-jupyter
PORT=8888
CMD="uv run --group notebook jupyter lab --no-browser --ip=127.0.0.1 --port=8888 --ServerApp.allow_remote_access=False --ServerApp.root_dir=research/tokenmm"
