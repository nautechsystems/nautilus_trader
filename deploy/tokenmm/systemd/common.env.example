# Copy to /etc/flux/common.env and fill in host-specific secrets.

WORKDIR=/home/ubuntu/nautilus-trader
PYTHONPATH=/home/ubuntu/nautilus-trader
PYTHONUNBUFFERED=1
LOG_LEVEL=INFO

NAUTILUS_TELEMETRY_PG_HOST=
NAUTILUS_TELEMETRY_PG_PORT=5432
NAUTILUS_TELEMETRY_PG_DATABASE=nautilus_telemetry
NAUTILUS_TELEMETRY_PG_SCHEMA=telemetry
NAUTILUS_TELEMETRY_PG_USERNAME=
NAUTILUS_TELEMETRY_PG_PASSWORD=
NAUTILUS_TELEMETRY_PG_SSLMODE=require

TOKENMM_REDIS_HOST=master.tokenmm.wapqos.apse1.cache.amazonaws.com
TOKENMM_REDIS_PORT=6379
TOKENMM_REDIS_DB=0
TOKENMM_REDIS_USERNAME=default
TOKENMM_REDIS_PASSWORD=
TOKENMM_REDIS_SSL=true

BYBIT_API_KEY=
BYBIT_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
