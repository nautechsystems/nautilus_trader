# Copy to /etc/flux/common.env and fill in host-specific secrets.

WORKDIR=/absolute/path/to/deploy-root
PYTHONPATH=/absolute/path/to/deploy-root
PYTHONUNBUFFERED=1

# Flux production services log to journald via flux@.service.
# Use FLUX_LOG_LEVEL as the global fallback, then override specific roles only when needed.
FLUX_LOG_LEVEL=INFO
FLUX_NODE_LOG_LEVEL=
FLUX_BRIDGE_LOG_LEVEL=
FLUX_PORTFOLIO_LOG_LEVEL=
FLUX_API_LOG_LEVEL=

NAUTILUS_TELEMETRY_PG_HOST=
NAUTILUS_TELEMETRY_PG_PORT=5432
NAUTILUS_TELEMETRY_PG_DATABASE=nautilus_telemetry
NAUTILUS_TELEMETRY_PG_SCHEMA=telemetry
NAUTILUS_TELEMETRY_PG_USERNAME=
NAUTILUS_TELEMETRY_PG_PASSWORD=
NAUTILUS_TELEMETRY_PG_SSLMODE=require

TOKENMM_REDIS_HOST=master.tokenmm.wapqos.apse1.cache.amazonaws.com
TOKENMM_REDIS_PORT=6379
TOKENMM_REDIS_DB=0
TOKENMM_REDIS_USERNAME=default
TOKENMM_REDIS_PASSWORD=
TOKENMM_REDIS_SSL=true
LP_API_BACKEND_URL=http://127.0.0.1:5025
TOKENMM_TELEMETRY_DIR=/var/lib/nautilus/telemetry/tokenmm

BYBIT_API_KEY=
BYBIT_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
