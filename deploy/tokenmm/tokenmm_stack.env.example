# Copy to deploy/tokenmm/tokenmm_stack.env for local paper/testnet smoke only.
# Production/live service management is unsupported through this env file.
# Use `sudo ops/scripts/deploy/install_tokenmm_systemd.sh`, fill `/etc/flux/common.env`,
# and manage the deployment through Pulse at `http://127.0.0.1:5022/pulse`.
BYBIT_API_KEY=
BYBIT_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# TokenMM stack controls.
# Safe default: paper mode with execution disabled.
TOKENMM_MODE=paper
TOKENMM_CONFIRM_LIVE=0
TOKENMM_ENABLE_EXECUTION=0
TOKENMM_ALLOW_MISSING_KEYS=0
TOKENMM_MANAGE_REDIS=0
TOKENMM_API_HOST=127.0.0.1
TOKENMM_API_PORT=5022
TOKENMM_EXPECTED_NODES=0
TOKENMM_START_TIMEOUT_SECS=90
TOKENMM_BALANCES_READY_TIMEOUT_SECS=90
TOKENMM_SKIP_FLUXBOARD_BUILD=0
TOKENMM_SKIP_PULSE_BUILD=0
TOKENMM_STRICT_BALANCES_READY_CHECK=1
TOKENMM_LOAD_AWS_SECRETS=0
TOKENMM_AWS_REGION=ap-southeast-1
TOKENMM_BYBIT_SECRET_ID=/nautilus/tokenmm/bybit
TOKENMM_BINANCE_SECRET_ID=/nautilus/tokenmm/binance
TOKENMM_BITGET_SECRET_ID=/nautilus/tokenmm/bitget
TOKENMM_OKX_SECRET_ID=/nautilus/tokenmm/okx
TOKENMM_REDIS_PASSWORD=
# Optional overrides if the shared deploy TOML needs an emergency runtime override:
# TOKENMM_REDIS_HOST=master.maker-v2-client-redis-prod.wapqos.apse1.cache.amazonaws.com
# TOKENMM_REDIS_PORT=6379
# TOKENMM_REDIS_USERNAME=default
# TOKENMM_REDIS_SSL=true

# Optional explicit paths.
# TOKENMM_CONFIG_PATH=/abs/path/to/deploy/tokenmm/tokenmm.live.toml
# TOKENMM_STRATEGIES_DIR=/abs/path/to/deploy/tokenmm/strategies
# TOKENMM_ENV_PATH=/abs/path/to/deploy/tokenmm/tokenmm_stack.env

# Optional smoke-only overrides:
# TOKENMM_ALLOW_MISSING_KEYS=1
# TOKENMM_STRICT_BALANCES_READY_CHECK=0
