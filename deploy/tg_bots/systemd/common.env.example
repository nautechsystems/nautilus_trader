# Copy to /etc/flux/common.env and fill in host-specific settings.

WORKDIR=/home/ubuntu/releases/prod/tg_bots/current
PYTHONPATH=/home/ubuntu/releases/prod/tg_bots/current
# Keep the host default pointed at an immutable release root, not a mutable checkout or `.worktrees/*`.
# Re-run `ops/scripts/deploy/install_tg_bots_systemd.sh` after changing the intended release root.
# Run `uv sync --all-groups --all-extras` in the selected release root first so
# the release-local `.venv/bin/python` exists for the installer guard.
PYTHONUNBUFFERED=1

# Flux production services log to journald via flux@.service.
FLUX_LOG_LEVEL=INFO
