# Copy to /etc/flux/common.env and fill in host-specific settings.
# trade[XYZ] credentials stay here so `/equities`, `profile=equities`, and
# `portfolio=equities` remain stable across per-stock strategy files.

WORKDIR=/home/ubuntu/nautilus-trader
PYTHONPATH=/home/ubuntu/nautilus-trader
# Re-run `ops/scripts/deploy/install_equities_systemd.sh` after changing checkout paths.
# Run `uv sync --all-groups --all-extras` in the selected checkout first so
# the checkout-local `.venv/bin/python` exists for the installer guard.
# Then verify every matching `/etc/flux/equities-node-*.env` and the other `/etc/flux/equities-*.env`
# files were rewritten with matching `WORKDIR=`, `PYTHONPATH=`, checkout-local `.venv/bin/python`,
# and live-mode flags before restarting services.
PYTHONUNBUFFERED=1

# Flux production services log to journald via flux@.service.
# Use FLUX_LOG_LEVEL as the global fallback, then override specific roles only when needed.
FLUX_LOG_LEVEL=INFO
FLUX_NODE_LOG_LEVEL=
FLUX_BRIDGE_LOG_LEVEL=
FLUX_PORTFOLIO_LOG_LEVEL=
FLUX_API_LOG_LEVEL=

# Dedicated equities Redis override for production hosts.
# Production ElastiCache replication group: `equities` in `ap-southeast-1`.
# Primary endpoint: `master.equities.wapqos.apse1.cache.amazonaws.com:6379`
# Reader endpoint: `replica.equities.wapqos.apse1.cache.amazonaws.com:6379`
EQUITIES_REDIS_HOST=
EQUITIES_REDIS_PORT=6379
EQUITIES_REDIS_DB=0
EQUITIES_REDIS_USERNAME=default
EQUITIES_REDIS_PASSWORD=
EQUITIES_REDIS_SSL=1
EQUITIES_API_BACKEND_URL=http://127.0.0.1:5024

# Required for trade[XYZ] execution on the shared Hyperliquid + dex="xyz" surface.
TRADE_XYZ_AGENT_PK=
TRADE_XYZ_ACCOUNT_ADDRESS=
TRADE_XYZ_VAULT_ADDRESS=
