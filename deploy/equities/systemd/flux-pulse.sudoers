  /usr/bin/systemctl start flux@equities-node-hood_binance_perp.service, \
  /usr/bin/systemctl stop flux@equities-node-hood_binance_perp.service, \
  /usr/bin/systemctl restart flux@equities-node-hood_binance_perp.service, \
