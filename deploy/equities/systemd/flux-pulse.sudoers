  /usr/bin/systemctl restart flux@equities-node-tsla_tradexyz_taker.service, \
  /usr/bin/journalctl -u flux@equities-node-tsla_tradexyz_taker.service

ubuntu ALL=(root) NOPASSWD: FLUX_PULSE
