  /usr/bin/systemctl stop flux@equities-node-nvda_tradexyz.service, \
  /usr/bin/systemctl restart flux@equities-node-nvda_tradexyz.service, \
  /usr/bin/journalctl -u flux@equities-node-nvda_tradexyz.service, \
  /usr/bin/systemctl start flux@equities-node-orcl_tradexyz.service, \
  /usr/bin/systemctl stop flux@equities-node-orcl_tradexyz.service, \
  /usr/bin/systemctl restart flux@equities-node-orcl_tradexyz.service, \
  /usr/bin/journalctl -u flux@equities-node-orcl_tradexyz.service, \
  /usr/bin/systemctl start flux@equities-node-pltr_tradexyz.service, \
  /usr/bin/systemctl stop flux@equities-node-pltr_tradexyz.service, \
  /usr/bin/systemctl restart flux@equities-node-pltr_tradexyz.service, \
  /usr/bin/journalctl -u flux@equities-node-pltr_tradexyz.service, \
