  /usr/bin/systemctl restart flux@equities-node-googl_tradexyz_maker.service, \
  /usr/bin/journalctl -u flux@equities-node-googl_tradexyz_maker.service, \
  /usr/bin/systemctl start flux@equities-node-googl_tradexyz_taker.service, \
  /usr/bin/systemctl stop flux@equities-node-googl_tradexyz_taker.service, \
  /usr/bin/systemctl restart flux@equities-node-googl_tradexyz_taker.service, \
  /usr/bin/journalctl -u flux@equities-node-googl_tradexyz_taker.service, \
  /usr/bin/systemctl start flux@equities-node-meta_tradexyz_maker.service, \
  /usr/bin/systemctl stop flux@equities-node-meta_tradexyz_maker.service, \
  /usr/bin/systemctl restart flux@equities-node-meta_tradexyz_maker.service, \
  /usr/bin/journalctl -u flux@equities-node-meta_tradexyz_maker.service, \
  /usr/bin/systemctl start flux@equities-node-meta_tradexyz_taker.service, \
  /usr/bin/systemctl stop flux@equities-node-meta_tradexyz_taker.service, \
