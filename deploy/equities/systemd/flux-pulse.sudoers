  /usr/bin/journalctl -u flux@equities-node-meta_tradexyz_taker.service, \
  /usr/bin/systemctl start flux@equities-node-msft_tradexyz_maker.service, \
  /usr/bin/systemctl stop flux@equities-node-msft_tradexyz_maker.service, \
  /usr/bin/systemctl restart flux@equities-node-msft_tradexyz_maker.service, \
