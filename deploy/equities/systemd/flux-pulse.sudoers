  /usr/bin/systemctl stop flux@equities-node-tsla_tradexyz.service, \
  /usr/bin/systemctl restart flux@equities-node-tsla_tradexyz.service, \
  /usr/bin/journalctl -u flux@equities-node-tsla_tradexyz.service, \
  /usr/bin/systemctl start flux@equities-node-amzn_binance_perp.service, \
  /usr/bin/systemctl stop flux@equities-node-amzn_binance_perp.service, \
  /usr/bin/systemctl restart flux@equities-node-amzn_binance_perp.service, \
  /usr/bin/journalctl -u flux@equities-node-amzn_binance_perp.service, \
  /usr/bin/systemctl start flux@equities-node-coin_binance_perp.service, \
  /usr/bin/systemctl stop flux@equities-node-coin_binance_perp.service, \
  /usr/bin/systemctl restart flux@equities-node-coin_binance_perp.service, \
