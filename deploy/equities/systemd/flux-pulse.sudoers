# Allow the API service user to operate managed Flux services for Pulse.
Cmnd_Alias FLUX_PULSE = \
  /usr/bin/systemctl start flux@equities-portfolio.service, \
  /usr/bin/systemctl stop flux@equities-portfolio.service, \
  /usr/bin/systemctl restart flux@equities-portfolio.service, \
  /usr/bin/journalctl -u flux@equities-portfolio.service, \
  /usr/bin/systemctl start flux@equities-bridge.service, \
  /usr/bin/systemctl stop flux@equities-bridge.service, \
  /usr/bin/systemctl restart flux@equities-bridge.service, \
  /usr/bin/journalctl -u flux@equities-bridge.service, \
  /usr/bin/systemctl start flux@equities-node-aapl_tradexyz.service, \
  /usr/bin/systemctl stop flux@equities-node-aapl_tradexyz.service, \
  /usr/bin/systemctl restart flux@equities-node-aapl_tradexyz.service, \
  /usr/bin/journalctl -u flux@equities-node-aapl_tradexyz.service, \
  /usr/bin/systemctl start flux@equities-node-amd_tradexyz.service, \
  /usr/bin/systemctl stop flux@equities-node-amd_tradexyz.service, \
  /usr/bin/systemctl restart flux@equities-node-amd_tradexyz.service, \
  /usr/bin/journalctl -u flux@equities-node-amd_tradexyz.service, \
  /usr/bin/systemctl start flux@equities-node-amzn_tradexyz.service, \
  /usr/bin/systemctl stop flux@equities-node-amzn_tradexyz.service, \
  /usr/bin/systemctl restart flux@equities-node-amzn_tradexyz.service, \
  /usr/bin/journalctl -u flux@equities-node-amzn_tradexyz.service, \
  /usr/bin/systemctl start flux@equities-node-googl_tradexyz.service, \
  /usr/bin/systemctl stop flux@equities-node-googl_tradexyz.service, \
  /usr/bin/systemctl restart flux@equities-node-googl_tradexyz.service, \
  /usr/bin/journalctl -u flux@equities-node-googl_tradexyz.service, \
  /usr/bin/systemctl start flux@equities-node-meta_tradexyz.service, \
  /usr/bin/systemctl stop flux@equities-node-meta_tradexyz.service, \
  /usr/bin/systemctl restart flux@equities-node-meta_tradexyz.service, \
  /usr/bin/journalctl -u flux@equities-node-meta_tradexyz.service, \
  /usr/bin/systemctl start flux@equities-node-msft_tradexyz.service, \
