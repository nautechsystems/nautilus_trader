# Copy to deploy/equities/equities_stack.env for local paper/testnet smoke only.
# Production/live service management should go through systemd/Pulse.
TRADE_XYZ_AGENT_PK=
TRADE_XYZ_ACCOUNT_ADDRESS=

# Equities stack controls.
EQUITIES_MODE=paper
EQUITIES_CONFIRM_LIVE=0
EQUITIES_ENABLE_EXECUTION=0
EQUITIES_ALLOW_MISSING_KEYS=0
EQUITIES_API_HOST=127.0.0.1
EQUITIES_API_PORT=5022
EQUITIES_SKIP_FLUXBOARD_BUILD=0
EQUITIES_SKIP_PULSE_BUILD=0
EQUITIES_LOAD_AWS_SECRETS=0
EQUITIES_AWS_REGION=ap-southeast-1
# Secret JSON may populate only TRADE_XYZ_AGENT_PK and TRADE_XYZ_ACCOUNT_ADDRESS.
EQUITIES_TRADE_XYZ_SECRET_ID=/nautilus/equities/trade_xyz

# Optional explicit paths.
# EQUITIES_CONFIG_PATH=/abs/path/to/deploy/equities/equities.live.toml
# EQUITIES_STRATEGIES_DIR=/abs/path/to/deploy/equities/strategies
# EQUITIES_ENV_PATH=/abs/path/to/deploy/equities/equities_stack.env
