# Copy to /etc/flux/common.env and fill in host-specific settings.
# LP hedgers resolve shared Redis, Plume RPC, and Bybit credentials from
# LP_SYSTEM_CONFIG with the same section/key names as chainsaw.

WORKDIR=/home/ubuntu/nautilus-trader
PYTHONPATH=/home/ubuntu/nautilus-trader
PYTHONUNBUFFERED=1

# Flux production services log to journald via flux@.service.
# Use FLUX_LOG_LEVEL as the global fallback, then override specific roles only when needed.
FLUX_LOG_LEVEL=INFO
FLUX_NODE_LOG_LEVEL=
FLUX_BRIDGE_LOG_LEVEL=
FLUX_PORTFOLIO_LOG_LEVEL=
FLUX_API_LOG_LEVEL=

# Restart `flux@tokenmm-api.service` after changing LP_API_BACKEND_URL so
# `/lp` and `/api/v1/hedgers/*` reload the hidden loopback backend on :5025.
LP_API_BACKEND_URL=http://127.0.0.1:5025
LP_SYSTEM_CONFIG=/etc/flux/lp-system.ini
PULSE_BASE_URL=http://127.0.0.1:5022/api/pulse
