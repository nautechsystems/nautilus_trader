# Copy to deploy/lp/lp_stack.env for local paper smoke only.
# Production/live service management should go through systemd/Pulse.

# LP stack controls.
LP_MODE=paper
LP_CONFIRM_LIVE=0
LP_ENABLE_EXECUTION=0
LP_API_HOST=127.0.0.1
LP_API_PORT=5025
LP_PUBLIC_HOST=127.0.0.1
LP_PUBLIC_PORT=5022
LP_SKIP_FLUXBOARD_BUILD=0
LP_SKIP_PULSE_BUILD=0

# Optional explicit paths.
# LP_CONFIG_PATH=/abs/path/to/deploy/lp/lp.live.toml
# LP_HEDGERS_DIR=/abs/path/to/deploy/lp/hedgers
# LP_ENV_PATH=/abs/path/to/deploy/lp/lp_stack.env
