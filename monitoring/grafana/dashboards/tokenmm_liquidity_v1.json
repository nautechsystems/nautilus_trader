          "legendFormat": "Uptime %",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "label_join(avg by (token,symbol,venue) (avg_over_time(tokenmm_quote_depth_usd_100bps{env=~\"$env\",token=~\"$token\",venue=~\"$venue\",symbol=~\"$symbol\"}[$window])), \"symbol_venue\", \"@\", \"symbol\", \"venue\")",
          "format": "table",
          "instant": true,
          "legendFormat": "Our Quote Depth 100bps (USD)",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "label_join(avg by (token,symbol,venue) (avg_over_time(tokenmm_quote_depth_usd_200bps{env=~\"$env\",token=~\"$token\",venue=~\"$venue\",symbol=~\"$symbol\"}[$window])), \"symbol_venue\", \"@\", \"symbol\", \"venue\")",
          "format": "table",
          "instant": true,
          "legendFormat": "Our Quote Depth 200bps (USD)",
          "refId": "C"
        }
      ],
      "title": "Quoting Uptime + Our Quote Depth Quality",
