      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "label_join(100 * avg by (token,symbol,venue) (avg_over_time(tokenmm_quote_up{env=~\"$env\",token=~\"$token\",venue=~\"$venue\",symbol=~\"$symbol\"}[$window])), \"symbol_venue\", \"@\", \"symbol\", \"venue\")",
