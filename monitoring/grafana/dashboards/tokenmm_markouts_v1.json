  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Snapshot of average resolved markout, resolution rate, and resolved row count by strategy, horizon, and side.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Resolution Rate"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Resolved Rows"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "pluginVersion": "10.2.3",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "label_join(avg by (strategy_id,horizon_s,order_side) (avg_over_time(tokenmm_markout_avg_bps{env=~\"$env\",profile=~\"$profile\",strategy_id=~\"$strategy_id\",order_side=~\"$order_side\",horizon_s=~\"$horizon_s\",benchmark_name=~\"$benchmark_name\"}[$window])), \"series_key\", \" | \", \"strategy_id\", \"horizon_s\", \"order_side\")",
          "format": "table",
          "instant": true,
          "legendFormat": "Average Markout Bps",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "label_join(avg by (strategy_id,horizon_s,order_side) (avg_over_time(tokenmm_markout_resolution_rate{env=~\"$env\",profile=~\"$profile\",strategy_id=~\"$strategy_id\",order_side=~\"$order_side\",horizon_s=~\"$horizon_s\",benchmark_name=~\"$benchmark_name\"}[$window])), \"series_key\", \" | \", \"strategy_id\", \"horizon_s\", \"order_side\")",
          "format": "table",
          "instant": true,
          "legendFormat": "Resolution Rate",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "label_join(max by (strategy_id,horizon_s,order_side) (tokenmm_markout_resolved_rows{env=~\"$env\",profile=~\"$profile\",strategy_id=~\"$strategy_id\",order_side=~\"$order_side\",horizon_s=~\"$horizon_s\",benchmark_name=~\"$benchmark_name\"}), \"series_key\", \" | \", \"strategy_id\", \"horizon_s\", \"order_side\")",
          "format": "table",
          "instant": true,
          "legendFormat": "Resolved Rows",
          "refId": "C"
        }
      ],
      "title": "Strategy + Horizon Snapshot",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "series_key",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "benchmark_name": true,
              "benchmark_name 1": true,
              "benchmark_name 2": true,
              "env": true,
              "horizon_s": true,
              "horizon_s 1": true,
              "horizon_s 2": true,
              "order_side": true,
              "order_side 1": true,
              "order_side 2": true,
              "profile": true,
              "profile 1": true,
              "profile 2": true,
              "strategy_id": true,
              "strategy_id 1": true,
              "strategy_id 2": true
            },
            "renameByName": {
              "Value #A": "Average Markout Bps",
              "Value #B": "Resolution Rate",
              "Value #C": "Resolved Rows",
              "series_key": "Strategy | Horizon | Side"
            }
          }
        }
      ],
      "type": "table"
    },
